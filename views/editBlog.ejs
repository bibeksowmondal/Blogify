<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>Edit Blog</title>
</head>

<body class="d-flex flex-column min-vh-100">

<%- include('./partials/nav') %>

<!-- Main Content -->
<main class="flex-fill">
<div class="container mt-4">

  <h2 class="text-white mb-4">Edit Blog</h2>

  <form action="/blog/edit/<%= blog._id %>" method="POST">

    <div class="mb-3">
      <label class="form-label text-light">Title</label>
      <input
        type="text"
        name="title"
        class="form-control"
        value="<%= blog.title %>"
        required
      />
    </div>

    <div class="mb-3">
      <label class="form-label text-light">Image URL</label>
      <input
        type="url"
        name="imageUrl"
        class="form-control"
        value="<%= blog.imageUrl %>"
      />
    </div>

    <div class="mb-3">
      <label class="form-label text-light">Content</label>
      <textarea
        name="content"
        class="form-control"
        rows="6"
        required
      ><%= blog.content %></textarea>
    </div>

    <button class="btn btn-success">Update Blog</button>
  </form>

</div>
</main>

<!-- Footer -->
<%- include('./partials/footer') %>

<%- include('./partials/scripts') %>

</body>
</html>