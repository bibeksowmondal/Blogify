<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./partials/head') %>
  <title>My Blogs</title>
</head>

<body class="d-flex flex-column min-vh-100">

<%- include('./partials/nav') %>

<!-- Main Content Wrapper -->
<main class="flex-fill">
<div class="container mt-5">

  <h2 class="text-white mb-4">My Blogs</h2>

  <% if (blogs.length === 0) { %>
    <div class="alert alert-info">
      You haven't written any blogs yet.
      <a href="/blog/add">Create your first blog</a>.
    </div>
  <% } %>

  <div class="row g-4">

  <% blogs.forEach(blog => { %>

    <div class="col-md-6 col-lg-4">
      <div class="card blog-card h-100">

        <% if (blog.imageUrl) { %>
          <img
            src="<%= blog.imageUrl %>"
            class="card-img-top"
            style="height: 200px; object-fit: cover;"
          >
        <% } %>

        <div class="card-body d-flex flex-column">

          <h5 class="card-title"><%= blog.title %></h5>

          <p class="text-muted small mb-3">
            <%= new Date(blog.createdAt).toDateString() %>
          </p>

          <div class="mt-auto">

            <a href="/blog/<%= blog._id %>" class="btn btn-sm btn-outline-primary">
              View
            </a>

            <a href="/blog/edit/<%= blog._id %>" class="btn btn-sm btn-warning">
              Edit
            </a>

            <form
              action="/blog/delete/<%= blog._id %>"
              method="POST"
              class="d-inline"
              onsubmit="return confirm('Delete this blog?');"
            >
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>

          </div>
        </div>
      </div>
    </div>

  <% }) %>

  </div>

</div>
</main>

<!-- Footer -->
<%- include('./partials/footer') %>

<%- include('./partials/scripts') %>

</body>
</html>